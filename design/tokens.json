{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "50": { "$value": "#FAF3E4", "$type": "color" },
        "100": { "$value": "#F2E6CC", "$type": "color" },
        "300": { "$value": "#DEC9A0", "$type": "color" },
        "600": { "$value": "#8C7B5E", "$type": "color" },
        "900": { "$value": "#2A2117", "$type": "color" }
      },
      "verdigris": {
        "300": { "$value": "#9DBFAE", "$type": "color" },
        "500": { "$value": "#587F6B", "$type": "color" },
        "700": { "$value": "#3C5E4C", "$type": "color" },
        "900": { "$value": "#1E3226", "$type": "color" }
      },
      "rust": {
        "400": { "$value": "#C97A52", "$type": "color" },
        "500": { "$value": "#A8522E", "$type": "color" },
        "700": { "$value": "#74311B", "$type": "color" },
        "900": { "$value": "#3D1810", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-public-sans), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-space-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.paper.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.paper.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.paper.600}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.paper.900}", "$type": "color" },
    "border": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.verdigris.500}", "$type": "color" },
    "radius": { "$value": "0.25rem", "$type": "dimension" },
    "verdigris": { "$value": "{primitive.color.verdigris.500}", "$type": "color" },
    "verdigris-dim": { "$value": "{primitive.color.verdigris.900}", "$type": "color" },
    "rust": { "$value": "{primitive.color.rust.500}", "$type": "color" },
    "rust-dim": { "$value": "{primitive.color.rust.900}", "$type": "color" },
    "ink": { "$value": "{primitive.color.paper.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 6.6vw, 5.4rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.05", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(88, 127, 107, 0.22), rgba(30, 50, 38, 0.1) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(42, 33, 23, 0.92) 0%, rgba(42, 33, 23, 0.28) 45%, rgba(42, 33, 23, 0.5) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.rust.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.rust.700}", "$type": "color" },
      "ghost-border": { "$value": "rgba(42, 33, 23, 0.28)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.rust.500}", "$type": "color" }
    }
  }
}
